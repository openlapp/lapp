{
  "schemaVersion": "1.0",
  "id": "moonshot-kimi",
  "name": "Kimi Open Platform",
  "enabled": true,
  "protocol": "openai-chat-completions",
  "baseUrl": "https://api.moonshot.cn/v1",
  "auth": {
    "type": "bearer",
    "secret": "env://MOONSHOT_API_KEY"
  },

  // Demonstrates provider requirements such as a Kimi coding plan User-Agent.
  // requestHeaders should only contain non-secret static headers, not Authorization.
  "requestHeaders": {
    "User-Agent": "LAPPExample/1.0 (+https://example.com/contact)"
  },

  "links": {
    "homepage": "https://platform.kimi.ai",
    "console": "https://platform.kimi.ai/console",
    "docs": "https://platform.kimi.ai/docs",
    "models": "https://platform.kimi.ai/docs/guide/kimi-k2-7-code-quickstart"
  }
}
