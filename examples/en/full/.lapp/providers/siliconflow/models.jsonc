  "schemaVersion": "1.0",
  "updatedAt": "2026-07-03T12:00:00+08:00",
  "models": [
    {
      // SiliconFlow embedding model. The real invocation name keeps the provider-required string.
      "id": "BAAI/bge-m3",
      "source": "provider",
      "name": "BGE-M3",
      "aliases": ["bge-m3", "embedding-default"],
      "type": "embedding",
      "inputModalities": ["text"],
      "outputModalities": ["embedding"],
      "capabilities": ["embedding"],
      "contextWindow": 8192,
      "enabled": true,
      "protocol": "openai-chat-completions",
      "links": {
        "docs": "https://docs.siliconflow.cn/en/api-reference/embeddings/create-embeddings",
        "modelPage": "https://siliconflow.cn/models"
      }
    },
    {
      // Demonstrates mapping a long model ID to short local aliases.
      "id": "deepseek-ai/DeepSeek-V4-Flash",
      "source": "manual",
      "name": "DeepSeek V4 Flash on SiliconFlow",
      "aliases": ["deepseek-v4-flash", "ds-v4-flash-sf"],
      "type": "chat",
      "inputModalities": ["text"],
      "outputModalities": ["text"],
      "capabilities": ["chat", "stream", "reasoning"],
      "contextWindow": 1000000,
      "enabled": true
    }
  ]
