{
  "schemaVersion": "1.0",
  "id": "siliconflow",
  "name": "SiliconFlow",
  "enabled": true,
  "protocol": "openai-chat-completions",
  "baseUrl": "https://api.siliconflow.cn/v1",
  "auth": {
    "type": "bearer",
    "secret": "env://SILICONFLOW_API_KEY"
  },
  "links": {
    "homepage": "https://siliconflow.cn",
    "console": "https://cloud.siliconflow.cn",
    "apiKey": "https://cloud.siliconflow.cn/account/ak",
    "docs": "https://docs.siliconflow.cn",
    "embeddings": "https://docs.siliconflow.cn/en/api-reference/embeddings/create-embeddings"
  }
}
